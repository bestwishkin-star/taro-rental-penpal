    "@tarojs/runtime": "^4.0.9",
    "@tarojs/shared": "^4.0.9",
    "@tarojs/taro": "^4.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@tarojs/cli": "^4.0.9",
    "@tarojs/plugin-framework-react": "^4.0.9",
    "@tarojs/plugin-platform-jd": "^4.0.9",
    "@tarojs/plugin-platform-tt": "^4.0.9",
    "@tarojs/plugin-platform-weapp": "^4.0.9",
    "@tarojs/webpack5-runner": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "babel-preset-taro": "^4.1.11",
    "cross-env": "^7.0.3",
    "sass": "^1.85.1"
  }
