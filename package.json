{
  "name": "taro-rental-penpal-v2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:frontend": "pnpm --filter @rental-penpal/frontend dev:weapp",
    "build:frontend": "pnpm --filter @rental-penpal/frontend build:weapp",
    "dev:backend": "pnpm --filter @rental-penpal/backend dev",
    "build:backend": "pnpm --filter @rental-penpal/backend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@next/eslint-plugin-next": "^15.2.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
